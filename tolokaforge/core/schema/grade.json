{
  "$id": "https://ulb-h/schemas/grade.json",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "binary_pass": {
      "type": "boolean"
    },
    "score": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "components": {
      "type": "object",
      "properties": {
        "state_checks": {
          "type": "number"
        },
        "transcript_rules": {
          "type": "number"
        },
        "llm_judge": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "reasons": {
      "type": "string"
    }
  },
  "required": ["binary_pass", "score"]
}
